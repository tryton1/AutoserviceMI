<Window x:Class="AutoserviceMI.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard" Height="449" Width="1166"
        Background="White">

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="Gray"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="DarkGray" BorderThickness="1" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Background="LightGray" Grid.RowSpan="8" CornerRadius="20"
                Margin="-10,0,10,5" Width="150"/>

        <TextBlock Grid.Column="0" Grid.Row="0"
                   Text="Dashboard" Foreground="White"
                   FontSize="16" VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>

        <Grid Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" Margin="10,0,10,0"
              VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <Border Background="#4A90E2" CornerRadius="10" Margin="5">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Programări azi" Foreground="White" HorizontalAlignment="Center" FontSize="14"/>
                    <TextBlock x:Name="CardProgramariAzi" Text="0" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="#D0021B" CornerRadius="10" Margin="5" Grid.Column="1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Urgente" Foreground="White" HorizontalAlignment="Center" FontSize="14"/>
                    <TextBlock x:Name="CardUrgente" Text="0" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>


            <Border Background="#7ED321" CornerRadius="10" Margin="5" Grid.Column="2">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Stoc mic" Foreground="White" HorizontalAlignment="Center" FontSize="14"/>
                    <TextBlock x:Name="CardStocMic" Text="0" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Image Grid.Column="2" Grid.Row="0" Source="/Resources/autentificat.png"
               Width="35" HorizontalAlignment="Right" Margin="0,0,10,0"
               VerticalAlignment="Center"/>

        <Button Content="Clienti" Grid.Row="1" Style="{StaticResource RoundedButton}" Background="#A9A9A9" Click="Button_Click"/>
        <Button Content="Vehicule" Grid.Row="2" Style="{StaticResource RoundedButton}" Background="#A9A9A9" Click="Button_Click_3"/>
        <Button Content="Programari" Grid.Row="3" Style="{StaticResource RoundedButton}" Background="#A9A9A9" Click="Button_Click_1"/>
        <Button Content="Reparatii" Grid.Row="4" Style="{StaticResource RoundedButton}" Background="#A9A9A9" Click="Button_Click_4"/>
        <Button Content="Piese" Grid.Row="5" Style="{StaticResource RoundedButton}" Background="#A9A9A9" Click="Button_Click_2"/>
        <Button Content="Setari" Grid.Row="6" Style="{StaticResource RoundedButton}" Background="#A9A9A9" Click="Button_Click_5"/>

        <Border Background="LightGray" Grid.Column="1" Grid.Row="1" Margin="70,10" CornerRadius="20">
            <TextBlock Text="Urgente" Foreground="White" FontSize="14"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <Border Background="LightGray" Grid.Column="2" Grid.Row="1" Margin="70,10" CornerRadius="20">
            <TextBlock Text="Programari azi" Foreground="White" FontSize="14"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <Border Background="LightGray" Grid.Column="1" Grid.Row="4" Margin="70,10" CornerRadius="20">
            <TextBlock Text="Stoc Mic" Foreground="White" FontSize="14"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <DataGrid Name="Programari_Urgente" AutoGenerateColumns="True"
                  Grid.Column="1" Grid.Row="2" Grid.RowSpan="2" Margin="38,0,40,0"/>

        <DataGrid Name="Programari_Azi" AutoGenerateColumns="True"
                  Grid.Column="2" Grid.Row="2" Grid.RowSpan="6" Margin="39,0,39,35"/>

        <DataGrid Name="Programari_Urgent" AutoGenerateColumns="True"
                  Grid.Column="1" Grid.Row="5" Grid.RowSpan="3" Margin="38,0,40,35"/>

    </Grid>
</Window>
