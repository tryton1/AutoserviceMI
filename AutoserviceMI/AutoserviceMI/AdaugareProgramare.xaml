<Window x:Class="AutoserviceMI.AdaugareProgramare"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoserviceMI"
        mc:Ignorable="d"
        Title="AdaugareProgramare" Height="613" Width="950">
    <Window.Resources>
                <Style x:Key="RoundedButton" TargetType="Button">
                    <Setter Property="Width" Value="120"/>
                    <Setter Property="Height" Value="35"/>
                    <Setter Property="Margin" Value="5" />
                    <Setter Property="Background" Value="Gray"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value=" 15" />
                    <Setter Property="Template">

                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                        CornerRadius="15"
                        BorderBrush="Gray" BorderThickness="1" Padding="5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

            </Window.Resources>

            <Grid Margin="10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="79"/>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="80"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="80"/>
                </Grid.RowDefinitions>


                <Border Background="LightGray" CornerRadius="15">
                    <DockPanel>
                        <TextBlock Text="Adaugare programare" Foreground="White" DockPanel.Dock="Bottom" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <Image Source="/Resources/programari.png" DockPanel.Dock="Left" Width="50" HorizontalAlignment="Center"/>
                    </DockPanel>
                </Border>
                <DockPanel Grid.Row="1">
                    <TextBlock Grid.Row="1" Text="Ora si Data" FontSize="20" HorizontalAlignment="Center" DockPanel.Dock="Top"></TextBlock>
                    <DatePicker x:Name="OraDataDatePicker" Width="250" Height="30"></DatePicker>
                </DockPanel>
                <DockPanel Grid.Row="2">
                    <TextBlock Text="Nume" FontSize="20" HorizontalAlignment="Center" DockPanel.Dock="Top"></TextBlock>
                    <TextBox x:Name="NumeTextBox" Height="30" Width="250"></TextBox>
                </DockPanel>
                <DockPanel Grid.Row="3">
                    <TextBlock Text="Numar telefon" FontSize="20" HorizontalAlignment="Center" DockPanel.Dock="Top"></TextBlock>
            <TextBox x:Name="NumarTelefonTextBox" Height="30" Width="250"></TextBox>
                </DockPanel>
                <DockPanel Grid.Row="4">
                    <TextBlock Text="Model automobil" FontSize="20" HorizontalAlignment="Center" DockPanel.Dock="Top"></TextBlock>
                    <TextBox x:Name="ModelAutomobilTextBox" Height="30" Width="250"></TextBox>
                </DockPanel>
                <DockPanel Grid.Row="5">
                    <TextBlock Text="An fabricare" FontSize="20" HorizontalAlignment="Center" DockPanel.Dock="Top"></TextBlock>
                    <TextBox x:Name="AnFabricareTextBox" Height="30" Width="250" ></TextBox>
                </DockPanel>

                <Button Grid.Row="7" Click="Button_Click">
                    <TextBlock Text="Adaugare programare" Foreground="White" DockPanel.Dock="Bottom" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Button>

    </Grid>
</Window> 
