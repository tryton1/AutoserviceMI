<Window x:Class="AutoserviceMI.Modificare_Programare"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modificare Programare"
        Height="738" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="Gray"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                BorderBrush="Gray" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Border Background="LightGray"
                CornerRadius="15">
            <DockPanel>
                <TextBlock Text="Modificare Programare"
                           Foreground="White" FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <Image Source="/Resources/programari.png"
                       DockPanel.Dock="Left" Width="50"/>
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="1">
            <TextBlock Text="Client" FontSize="20"
                       DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <ComboBox x:Name="ClientCombo"/>
        </DockPanel>

        <DockPanel Grid.Row="2">
            <TextBlock Text="Vehicul" FontSize="20"
                       DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <ComboBox x:Name="VehiculCombo"/>
        </DockPanel>

        <DockPanel Grid.Row="3">
            <TextBlock Text="Data programării" FontSize="20"
                       DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <DatePicker x:Name="DataPicker"
                        Width="250" Height="30"/>
        </DockPanel>

        <DockPanel Grid.Row="4">
            <TextBlock Text="Tip intervenție" FontSize="20"
                       DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <TextBox x:Name="TipInterventieTextBox"/>
        </DockPanel>

        <DockPanel Grid.Row="5">
            <TextBlock Text="Mecanic" FontSize="20"
                       DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <TextBox x:Name="MecanicTextBox"/>
        </DockPanel>

        <DockPanel Grid.Row="6">
            <TextBlock Text="Stare" FontSize="20"
                       DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <ComboBox x:Name="StareCombo"
                      Width="250">
                <ComboBoxItem Content="Planificată"/>
                <ComboBoxItem Content="În progres"/>
                <ComboBoxItem Content="Finalizată"/>
                <ComboBoxItem Content="Anulată"/>
            </ComboBox>
        </DockPanel>

        <Button Grid.Row="7"
                Style="{StaticResource RoundedButton}"
                Click="SalvareModificari_Click">
            <TextBlock Text="Salvează Modificările"
                       FontSize="18"
                       Foreground="White"/>
        </Button>

    </Grid>
</Window>
