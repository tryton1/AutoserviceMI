<Window x:Class="AutoserviceMI.Resources.Piese_Reparatie"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Piese Reparatie" Height="500" Width="900">

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Width" Value="150"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="Gray"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                BorderBrush="Gray"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Grid.RowSpan="2"
                Background="LightGray"
                CornerRadius="15"
                Padding="10"
                Margin="-20,60,0,0">

            <StackPanel VerticalAlignment="Top">
                <Button Content="Adauga piesa"
                        Style="{StaticResource RoundedButton}"
                        x:Name="BtnAddPiesa"/>

                <Button Content="Sterge piesa"
                        Style="{StaticResource RoundedButton}"
                        x:Name="BtnDeletePiesa"/>

                <Button Content="Inchide"
                        Style="{StaticResource RoundedButton}"
                        x:Name="BtnClose"/>

                <Image Source="/Resources/cheie.png"
                       Width="100"
                       Margin="40"/>
            </StackPanel>

        </Border>

        <Border Grid.ColumnSpan="2"
                Background="LightGray"
                CornerRadius="15"
                Padding="10"
                Margin="-20,0,470,0">

            <DockPanel>
                <TextBlock Text="Piese folosite"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="40,0,0,0"/>
                <Image Source="/Resources/depozit.png"
                       Width="50"/>
            </DockPanel>

        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Background="White"
                CornerRadius="10"
                Padding="10"
                BorderThickness="1"
                BorderBrush="LightGray">

            <DataGrid x:Name="DataGridPiese"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Piesa"
                                        Binding="{Binding Produs.Denumire}"
                                        Width="160"/>

                    <DataGridTextColumn Header="Cantitate"
                                        Binding="{Binding Cantitate}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Pret unitar"
                                        Binding="{Binding PretUnitate}"
                                        Width="100"/>

                    <DataGridTextColumn Header="Pret total"
                                        Binding="{Binding PretTotal}"
                                        Width="100"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>
</Window>
