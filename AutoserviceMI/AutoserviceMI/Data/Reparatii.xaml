<Window x:Class="AutoserviceMI.Reparatii"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Reparatii" Height="650" Width="1100">

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Width" Value="130"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="Gray"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                BorderBrush="Gray" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- MENIU STÂNGA -->
        <Border Grid.Column="0" Grid.RowSpan="3" Background="LightGray" CornerRadius="15"
                Padding="10" Margin="-20,60,0,0">
            <StackPanel VerticalAlignment="Top">

                <Button Content="Adaugare" Style="{StaticResource RoundedButton}"
                        x:Name="BtnAdd" Click="BtnAdd_Click"/>

                <Button Content="Modificare" Style="{StaticResource RoundedButton}"
                        x:Name="BtnEdit" Click="BtnEdit_Click"/>

                <Button Content="Stergere" Style="{StaticResource RoundedButton}"
                        x:Name="BtnDelete" Click="BtnDelete_Click"/>

                <Button Content="Piese folosite" Style="{StaticResource RoundedButton}"
                        x:Name="BtnPiese" Click="BtnPiese_Click"/>

                <Button Content="Finalizeaza" Style="{StaticResource RoundedButton}"
                        x:Name="BtnFinalizeaza" Click="BtnFinalizeaza_Click"/>

                <Button Content="Filtrare" Style="{StaticResource RoundedButton}"
                        x:Name="BtnFiltrare" Click="BtnFiltrare_Click"/>

                <Image Source="/Resources/reparatii.png" Width="100" Margin="40"/>
            </StackPanel>
        </Border>

        <!-- HEADER -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="LightGray" CornerRadius="15"
                Padding="10" Margin="-20,0,470,0">
            <DockPanel>
                <TextBlock Text="Reparatii auto" Foreground="White" FontSize="20"
                           FontWeight="Bold" Margin="40,0,0,0"/>
                <Image Source="/Resources/reparatii.png" Width="50"/>
            </DockPanel>
        </Border>

        <!-- TABLA REPARATII -->
        <Border Grid.Row="1" Grid.Column="1" Background="White" CornerRadius="10" Padding="10"
                BorderBrush="LightGray" BorderThickness="1">

            <DataGrid Name="DataGridReparatii"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      SelectionChanged="DataGridReparatii_SelectionChanged">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Client"
                                        Binding="{Binding Client.Nume}"
                                        Width="140"/>

                    <DataGridTextColumn Header="Vehicul"
                                        Binding="{Binding Vehicul.Model}"
                                        Width="140"/>

                    <DataGridTextColumn Header="Nr. Inmatriculare"
                                        Binding="{Binding Vehicul.NumarInmatriculare}"
                                        Width="140"/>

                    <DataGridTextColumn Header="Tip Interventie"
                                        Binding="{Binding TipInterventie}"
                                        Width="140"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Mecanic"
                                        Binding="{Binding Mecanic}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Data Start"
                                        Binding="{Binding DataStart}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Data Finalizare"
                                        Binding="{Binding DataFinalizare}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Cost Estimat"
                                        Binding="{Binding CostEstimat}"
                                        Width="120"/>

                </DataGrid.Columns>

            </DataGrid>
        </Border>

        <!-- CARDURI DETALII -->
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal"
                    HorizontalAlignment="Center">

            <Border Background="LightGray" CornerRadius="10"
                    Padding="15" Width="180" Margin="10">
                <StackPanel>
                    <TextBlock Text="Status curent" Foreground="White" FontSize="16"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CardStatus" Text="-" Foreground="White"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="LightGray" CornerRadius="10"
                    Padding="15" Width="180" Margin="10">
                <StackPanel>
                    <TextBlock Text="Mecanic" Foreground="White" FontSize="16"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CardMecanic" Text="-" Foreground="White"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="LightGray" CornerRadius="10"
                    Padding="15" Width="180" Margin="10">
                <StackPanel>
                    <TextBlock Text="Cost Total" Foreground="White" FontSize="16"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CardCost" Text="-" Foreground="White"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="LightGray" CornerRadius="10"
                    Padding="15" Width="180" Margin="10">
                <StackPanel>
                    <TextBlock Text="Tip Interventie" Foreground="White" FontSize="16"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CardTip" Text="-" Foreground="White"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>

    </Grid>
</Window>
