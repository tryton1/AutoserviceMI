<Window x:Class="AutoserviceMI.Clienti"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Clienti" Height="550" Width="900">

    <Window.Resources>

        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="Gray"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                BorderBrush="Gray" BorderThickness="1" Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- LAYOUT PRINCIPAL -->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="150"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- TITLU -->
        <Border Grid.Row="0" Background="LightGray" CornerRadius="20" Padding="15">
            <TextBlock Text="Clienti"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- ROW 1: Butoane + Filtre -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Butoane principale -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Grid.Row="0">

                <Button Content="Home" Style="{StaticResource RoundedButton}" Margin="5" Click="Home_Click"/>
                <Button Content="Adauga Client" Style="{StaticResource RoundedButton}" Margin="5" Click="Button_Click"/>
                <Button Content="Modificare" Style="{StaticResource RoundedButton}" Margin="5" Click="Modificare_Click"/>
                <Button Content="Stergere" Style="{StaticResource RoundedButton}" Margin="5" Click="Stergere_Button_Click"/>

            </StackPanel>

            <!-- FILTRE -->
            <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="0,15,0,0"
            Grid.Row="1">

                <StackPanel Margin="5">
                    <Label Content="Nume" Foreground="Black" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBox x:Name="NumeFilterTextBox"
                 Style="{StaticResource RoundedTextBox}"
                 Width="120" Height="26"/>
                </StackPanel>

                <StackPanel Margin="5">
                    <Label Content="Prenume" Foreground="Black" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBox x:Name="PrenumeFilterTextBox"
                 Style="{StaticResource RoundedTextBox}"
                 Width="120" Height="26"/>
                </StackPanel>

                <StackPanel Margin="5">
                    <Label Content="Telefon" Foreground="Black" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBox x:Name="TelefonFilterTextBox"
                 Style="{StaticResource RoundedTextBox}"
                 Width="120" Height="26"/>
                </StackPanel>

                <StackPanel Margin="5">
                    <Label Content="Oras" Foreground="Black" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBox x:Name="OrasFilterTextBox"
                 Style="{StaticResource RoundedTextBox}"
                 Width="120" Height="26"/>
                </StackPanel>

                <Button Content="Filtrare"
            Style="{StaticResource RoundedButton}"
            Background="#A9A9A9"
            Width="100"
            Height="35"
            Margin="10"
            Click="Filtrare_Click"/>
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="2" Margin="0,10,0,0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Name="ClientiDataGrid">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="*"/>
                <DataGridTextColumn Header="Prenume" Binding="{Binding Prenume}" Width="*"/>
                <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="*"/>
                <DataGridTextColumn Header="Oras" Binding="{Binding Oras}" Width="*"/>
            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>
