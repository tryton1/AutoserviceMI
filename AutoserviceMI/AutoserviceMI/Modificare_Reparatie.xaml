<Window x:Class="AutoserviceMI.Modificare_Reparatie"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modificare Reparatie" Height="650" Width="900">

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="Gray"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <Border Background="LightGray" CornerRadius="15">
            <DockPanel>
                <TextBlock Text="Modificare Reparatie"
                           Foreground="White" FontSize="22" FontWeight="Bold"
                           DockPanel.Dock="Bottom" HorizontalAlignment="Center"/>
                <Image Source="/Resources/programari.png" Width="50"/>
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="1">
            <TextBlock Text="Tip Interventie" FontSize="20" DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <ComboBox x:Name="TipInterventieCombo"/>
        </DockPanel>

        <DockPanel Grid.Row="2">
            <TextBlock Text="Mecanic" FontSize="20" DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <TextBox x:Name="MecanicText"/>
        </DockPanel>

        <DockPanel Grid.Row="3">
            <TextBlock Text="Descriere" FontSize="20" DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <TextBox x:Name="DescriereText"/>
        </DockPanel>

        <DockPanel Grid.Row="4">
            <TextBlock Text="Status" FontSize="20" DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <ComboBox x:Name="StatusCombo"/>
        </DockPanel>

        <DockPanel Grid.Row="5">
            <TextBlock Text="Data Finalizare" FontSize="20" DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <DatePicker x:Name="DataFinalizarePicker"/>
        </DockPanel>

        <StackPanel Grid.Row="6" HorizontalAlignment="Center">
            <Button Style="{StaticResource RoundedButton}" Click="SalvareModificare_Click">
                <TextBlock Text="Salvează Modificările" FontSize="18"/>
            </Button>
        </StackPanel>

    </Grid>
</Window>
