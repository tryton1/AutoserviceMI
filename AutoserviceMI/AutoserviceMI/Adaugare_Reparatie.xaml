<Window x:Class="AutoserviceMI.Adaugare_Reparatie"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adaugare Reparatie" Height="702" Width="900">

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="Gray"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15" BorderBrush="Gray" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <Border Background="LightGray" CornerRadius="15">
            <DockPanel>
                <TextBlock Text="Adaugare Reparatie"
                           Foreground="White" FontSize="22"
                           FontWeight="Bold"
                           DockPanel.Dock="Bottom"
                           HorizontalAlignment="Center"/>
                <Image Source="/Resources/programari.png"
                       Width="50" DockPanel.Dock="Left"/>
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="1">
            <TextBlock Text="Client" FontSize="20" DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <ComboBox x:Name="ClientCombo" Width="250" Margin="5"/>
        </DockPanel>

        <DockPanel Grid.Row="2">
            <TextBlock Text="Vehicul" FontSize="20" DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <ComboBox x:Name="VehiculCombo" Width="250" Margin="5"/>
        </DockPanel>

        <DockPanel Grid.Row="3">
            <TextBlock Text="Tip Interventie" FontSize="20" DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <ComboBox x:Name="TipInterventieCombo" Width="250" Margin="5"/>
        </DockPanel>

        <DockPanel Grid.Row="4">
            <TextBlock Text="Mecanic" FontSize="20" DockPanel.Dock="Top" HorizontalAlignment="Center"/>
            <TextBox x:Name="MecanicText"/>
        </DockPanel>

        <Grid Grid.Row="5" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Cost Estimat" FontSize="18" HorizontalAlignment="Center"/>
                <TextBox x:Name="CostText"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Data Start" FontSize="18" HorizontalAlignment="Center"/>
                <DatePicker x:Name="DataStartPicker"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="6" VerticalAlignment="Top" HorizontalAlignment="Center">
            <Button Style="{StaticResource RoundedButton}" Click="SalvareReparatie_Click">
                <TextBlock Text="Adauga Reparatie" FontSize="18" Foreground="White"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
